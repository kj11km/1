-- AIMBOT  (fully fixed)
-- Key fixes:
--  1. aimKeyHeld tracked via InputBegan/Ended on ALL input, no stale
--     closure — we check the CURRENT key at event time AND store which
--     input started the hold so InputEnded can match it exactly.
--  2. Visibility raycast: origin is offset from myRoot, and the ray
--     ends just short of the bone so it can't hit the target itself.
--     We only skip if something OTHER than the target character blocks it.
--  3. Smoothing: alpha = dt / (smoothing + dt)  — frame-rate independent
--     exponential decay. smoothing=0 → instant, smoothing=0.3 → ~300ms.
--  4. Camera lerp uses slerp on rotation component via CFrame:Lerp which
--     already does quaternion slerp internally — no gimbal issues.
-- ══════════════════════════════════════════════════════════════
local AIM_KEYS = {
    { label="RMB", mouse=true,  input=Enum.UserInputType.MouseButton2 },
    { label="LMB", mouse=true,  input=Enum.UserInputType.MouseButton1 },
    { label="E",   mouse=false, input=Enum.KeyCode.E  },
    { label="Q",   mouse=false, input=Enum.KeyCode.Q  },
    { label="F",   mouse=false, input=Enum.KeyCode.F  },
    { label="V",   mouse=false, input=Enum.KeyCode.V  },
    { label="Z",   mouse=false, input=Enum.KeyCode.Z  },
    { label="X",   mouse=false, input=Enum.KeyCode.X  },
}
local BONE_NAMES   = { "Head", "UpperTorso", "Torso", "HumanoidRootPart" }
local BONE_LABELS  = { "Head", "UpperTorso", "Torso", "Root" }

-- Track exactly which input object started the hold so we can match on end
local aimHoldInput = nil   -- the actual InputObject that started the hold

local function IsAimInput(inp)
    local k = AIM_KEYS[CFG.aimbotKeyIdx]; if not k then return false end
    if k.mouse then return inp.UserInputType == k.input
    else             return inp.KeyCode       == k.input end
end

UserInputService.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if IsAimInput(inp) then aimHoldInput = inp end
end)
UserInputService.InputEnded:Connect(function(inp)
    -- Release when the exact same input object ends, OR when matching type ends
    if inp == aimHoldInput then aimHoldInput = nil; return end
    if IsAimInput(inp) then aimHoldInput = nil end
end)

local function AimKeyHeld()
    if not aimHoldInput then return false end
    -- Guard: if key was changed while held, release
    if not IsAimInput(aimHoldInput) then aimHoldInput = nil; return false end
    return aimHoldInput.UserInputState == Enum.UserInputState.Begin
end

