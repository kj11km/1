-- SegPick — row of mutually-exclusive buttons
-- onChange(idx, label)  called ONCE per click only
local function SegPick(parent,opts,default,onChange)
    local n=#opts; local card=Card(parent,34); local btns={}
    local function Highlight(sel)
        for i,b in ipairs(btns) do
            TweenService:Create(b,TweenInfo.new(0.1),{
                BackgroundColor3=i==sel and C.accent or C.slBg,
                TextColor3      =i==sel and C.txtPri  or C.txtDim,
            }):Play()
        end
    end
    local gap=3; local bw=math.floor((CW-4-gap*(n-1))/n)
    for i,opt in ipairs(opts) do
        local b=Instance.new("TextButton",card)
        b.Size=UDim2.new(0,bw,1,-8); b.Position=UDim2.new(0,(i-1)*(bw+gap),0,4)
        b.BackgroundColor3=i==default and C.accent or C.slBg; b.BorderSizePixel=0
        b.Font=Enum.Font.GothamBold; b.TextSize=10
        b.TextColor3=i==default and C.txtPri or C.txtDim; b.Text=opt
        Instance.new("UICorner",b).CornerRadius=UDim.new(0,7); btns[i]=b
        b.MouseButton1Click:Connect(function()
            Highlight(i); onChange(i,opt)
        end)
    end
    return card
end
