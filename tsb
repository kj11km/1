local Players = game:GetService("Players") local RunService = game:GetService("RunService") local UserInputService = game:GetService("UserInputService") local TweenService = game:GetService("TweenService") local StarterGui = game:GetService("StarterGui") local LocalPlayer = Players.LocalPlayer local Workspace = game:GetService("Workspace") local Camera = Workspace.CurrentCamera -- ══════════════════════════════════════════════════════════════ -- KEY SYSTEM -- ══════════════════════════════════════════════════════════════ local VALID_KEY = "xiaoyangsb" local SAVE_FILE = "solar_key.txt" local keyUnlocked = false local function IsSaved() pcall(function() if readfile and isfile and isfile(SAVE_FILE) then local s = readfile(SAVE_FILE) if s and s:gsub("%s","") == VALID_KEY then keyUnlocked = true end end end) end local function SaveKey() pcall(function() if writefile then writefile(SAVE_FILE, VALID_KEY) end end) end IsSaved() -- ══════════════════════════════════════════════════════════════ -- CONFIG -- ══════════════════════════════════════════════════════════════ local CFG = { espEnabled = true, espMaxDist = 800, espTeamColors = true, espTeamColor = Color3.fromRGB(50, 130, 255), espEnemyColor = Color3.fromRGB(255, 55, 55), espBox = true, espHighlight = true, espNames = true, espHealth = true, espTracers = true, espDistance = true, aimbotEnabled = false, aimbotBone = "Head", aimbotFOV = 150, aimbotSmoothing = 0.12, -- 0=instant 1=never arrives aimbotTeamCheck = true, aimbotVisible = false, -- wallbang check (off by default, games vary) aimbotKeyIdx = 1, } -- ══════════════════════════════════════════════════════════════ -- HELPERS -- ══════════════════════════════════════════════════════════════ local function GetChar() return LocalPlayer.Character end local function GetRoot() local c = GetChar(); return c and c:FindFirstChild("HumanoidRootPart") end local function IsTeammate(pl) return LocalPlayer.Team ~= nil and pl.Team ~= nil and pl.Team == LocalPlayer.Team end local function ESPColor(pl) if CFG.espTeamColors and IsTeammate(pl) then return CFG.espTeamColor end return CFG.espEnemyColor end local function WorldToScreen(worldPos) local v = Camera:WorldToViewportPoint(worldPos) return Vector2.new(v.X, v.Y), v.Z > 0 end -- ══════════════════════════════════════════════════════════════ -- ESP -- ══════════════════════════════════════════════════════════════ local espFolder = Instance.new("Folder", Workspace); espFolder.Name = "_ESP" local espObjects = {} local function CreateESP(pl) if pl == LocalPlayer or espObjects[pl] then return end local obj = {} local box = Instance.new("SelectionBox") box.LineThickness = 0.055 box.SurfaceTransparency = 0.93 box.Color3 = CFG.espEnemyColor box.SurfaceColor3 = CFG.espEnemyColor box.Parent = espFolder obj.box = box local hl = Instance.new("Highlight") hl.FillTransparency = 0.72 hl.OutlineTransparency = 0 hl.FillColor = CFG.espEnemyColor hl.OutlineColor = CFG.espEnemyColor hl.Parent = espFolder obj.hl = hl local bb = Instance.new("BillboardGui") bb.Size = UDim2.new(0, 200, 0, 64) bb.StudsOffset = Vector3.new(0, 3.4, 0) bb.AlwaysOnTop = true bb.LightInfluence= 0 bb.Parent = espFolder obj.bb = bb local function Lbl(y, sz, col) local l = Instance.new("TextLabel", bb) l.Size = UDim2.new(1,0,0,18); l.Position = UDim2.new(0,0,0,y) l.BackgroundTransparency = 1; l.Font = Enum.Font.GothamBold l.TextSize = sz; l.TextColor3 = col; l.TextStrokeTransparency = 0.28; l.Text = "" return l end obj.nameLbl = Lbl(0, 13, Color3.new(1,1,1)) obj.hpLbl = Lbl(19, 11, Color3.fromRGB(110,255,110)) obj.distLbl = Lbl(36, 10, Color3.fromRGB(180,180,255)) local tr = Drawing.new("Line") tr.Visible=false; tr.Thickness=1.4; tr.Transparency=0.20; tr.Color=CFG.espEnemyColor obj.tracer = tr espObjects[pl] = obj end local function RemoveESP(pl) local obj = espObjects[pl]; if not obj then return end pcall(function() obj.box:Destroy() end) pcall(function() obj.hl:Destroy() end) pcall(function() obj.bb:Destroy() end) pcall(function() obj.tracer:Remove() end) espObjects[pl] = nil end local function HideObj(obj) obj.box.Adornee = nil; obj.hl.Adornee = nil obj.bb.Adornee = nil; obj.tracer.Visible = false end local function UpdateESP() if not CFG.espEnabled then for _, obj in pairs(espObjects) do HideObj(obj) end; return end local myRoot = GetRoot() for _, pl in pairs(Players:GetPlayers()) do if pl == LocalPlayer then continue end if not espObjects[pl] then CreateESP(pl) end local obj = espObjects[pl]; if not obj then continue end local tChar = pl.Character if not tChar then HideObj(obj); continue end local tRoot = tChar:FindFirstChild("HumanoidRootPart") if not tRoot then HideObj(obj); continue end local dist = myRoot and (tRoot.Position-myRoot.Position).Magnitude or 0 if dist > CFG.espMaxDist then HideObj(obj); continue end local col = ESPColor(pl) local tHum = tChar:FindFirstChildOfClass("Humanoid") obj.box.Adornee = CFG.espBox and tChar or nil obj.box.Color3 = col; obj.box.SurfaceColor3 = col obj.hl.Adornee = CFG.espHighlight and tChar or nil obj.hl.FillColor = col; obj.hl.OutlineColor = col obj.bb.Adornee = tChar obj.nameLbl.Visible = CFG.espNames obj.nameLbl.Text = pl.Name obj.nameLbl.TextColor3 = col if CFG.espHealth and tHum then local hp = math.floor(tHum.Health) local mx = math.max(tHum.MaxHealth,1) local pct = hp / mx obj.hpLbl.Visible = true obj.hpLbl.Text = ("HP %d/%d"):format(hp, math.floor(mx)) obj.hpLbl.TextColor3 = Color3.fromRGB(math.floor(255*(1-pct)), math.floor(255*pct), 50) else obj.hpLbl.Visible = false end obj.distLbl.Visible = CFG.espDistance if CFG.espDistance then obj.distLbl.Text = ("%d st"):format(math.floor(dist)) end if CFG.espTracers then local sp, vis = WorldToScreen(tRoot.Position) if vis then local vp = Camera.ViewportSize obj.tracer.From = Vector2.new(vp.X/2, vp.Y) obj.tracer.To = sp; obj.tracer.Color = col; obj.tracer.Visible = true else obj.tracer.Visible = false end else obj.tracer.Visible = false end end end Players.PlayerRemoving:Connect(RemoveESP) Players.PlayerAdded:Connect(CreateESP) for _, pl in pairs(Players:GetPlayers()) do CreateESP(pl) end -- ══════════════════════════════════════════════════════════════ -- AIMBOT (fully fixed) -- Key fixes: -- 1. aimKeyHeld tracked via InputBegan/Ended on ALL input, no stale -- closure — we check the CURRENT key at event time AND store which -- input started the hold so InputEnded can match it exactly. -- 2. Visibility raycast: origin is offset from myRoot, and the ray -- ends just short of the bone so it can't hit the target itself. -- We only skip if something OTHER than the target character blocks it. -- 3. Smoothing: alpha = dt / (smoothing + dt) — frame-rate independent -- exponential decay. smoothing=0 → instant, smoothing=0.3 → ~300ms. -- 4. Camera lerp uses slerp on rotation component via CFrame:Lerp which -- already does quaternion slerp internally — no gimbal issues. -- ══════════════════════════════════════════════════════════════ local AIM_KEYS = { { label="RMB", mouse=true, input=Enum.UserInputType.MouseButton2 }, { label="LMB", mouse=true, input=Enum.UserInputType.MouseButton1 }, { label="E", mouse=false, input=Enum.KeyCode.E }, { label="Q", mouse=false, input=Enum.KeyCode.Q }, { label="F", mouse=false, input=Enum.KeyCode.F }, { label="V", mouse=false, input=Enum.KeyCode.V }, { label="Z", mouse=false, input=Enum.KeyCode.Z }, { label="X", mouse=false, input=Enum.KeyCode.X }, } local BONE_NAMES = { "Head", "UpperTorso", "Torso", "HumanoidRootPart" } local BONE_LABELS = { "Head", "UpperTorso", "Torso", "Root" } -- Track exactly which input object started the hold so we can match on end local aimHoldInput = nil -- the actual InputObject that started the hold local function IsAimInput(inp) local k = AIM_KEYS[CFG.aimbotKeyIdx]; if not k then return false end if k.mouse then return inp.UserInputType == k.input else return inp.KeyCode == k.input end end UserInputService.InputBegan:Connect(function(inp, gpe) if gpe then return end if IsAimInput(inp) then aimHoldInput = inp end end) UserInputService.InputEnded:Connect(function(inp) -- Release when the exact same input object ends, OR when matching type ends if inp == aimHoldInput then aimHoldInput = nil; return end if IsAimInput(inp) then aimHoldInput = nil end end) local function AimKeyHeld() if not aimHoldInput then return false end -- Guard: if key was changed while held, release if not IsAimInput(aimHoldInput) then aimHoldInput = nil; return false end return aimHoldInput.UserInputState == Enum.UserInputState.Begin end -- Drawing objects local fovCircle = Drawing.new("Circle") fovCircle.Radius=CFG.aimbotFOV; fovCircle.Thickness=1.6 fovCircle.Color=Color3.fromRGB(255,70,70); fovCircle.Transparency=0.28 fovCircle.Filled=false; fovCircle.Visible=false local aimDot = Drawing.new("Circle") aimDot.Radius=5; aimDot.Thickness=2; aimDot.Color=Color3.fromRGB(255,225,0) aimDot.Transparency=0; aimDot.Filled=true; aimDot.Visible=false local function GetBestTarget() local vp = Camera.ViewportSize local center = Vector2.new(vp.X/2, vp.Y/2) local myChar = GetChar() local myRoot = GetRoot() local best, bestDist = nil, CFG.aimbotFOV for _, pl in pairs(Players:GetPlayers()) do if pl == LocalPlayer then continue end if CFG.aimbotTeamCheck and IsTeammate(pl) then continue end local tChar = pl.Character; if not tChar then continue end local hum = tChar:FindFirstChildOfClass("Humanoid") if not hum or hum.Health <= 0 then continue end local bone = tChar:FindFirstChild(CFG.aimbotBone) or tChar:FindFirstChild("Head") or tChar:FindFirstChild("UpperTorso") or tChar:FindFirstChild("HumanoidRootPart") if not bone then continue end -- ── FIXED visibility check ──────────────────────────── -- Only run if enabled AND we have a valid root if CFG.aimbotVisible and myRoot then local origin = myRoot.Position local dir = bone.Position - origin local dist = dir.Magnitude if dist > 1 then -- Offset origin slightly forward, stop 1 stud before bone -- so we don't clip our own character or the target's hitbox local ray = Ray.new( origin + dir.Unit * 3, dir.Unit * math.max(dist - 4, 0.1) ) local hit = Workspace:FindPartOnRayWithIgnoreList( ray, { myChar, tChar, espFolder } ) -- hit=nil means clear line of sight → proceed -- hit=something means blocked → skip this target if hit then continue end end end -- Project to screen space local raw = Camera:WorldToViewportPoint(bone.Position) if raw.Z <= 0 then continue end -- behind camera local sp = Vector2.new(raw.X, raw.Y) local d = (sp - center).Magnitude if d < bestDist then bestDist = d best = { worldPos=bone.Position, screenPos=sp } end end return best end -- ── FIXED smooth aim ────────────────────────────────────────── -- Frame-rate independent using delta time. -- alpha = dt / (smoothing_seconds + dt) -- At dt=1/60 and smoothing=0.12 → alpha ≈ 0.33 per frame → ~3 frames to lock -- At smoothing=0 → alpha=1 → instant snap every frame local lastDt = 1/60 local function SmoothAim(target, dt) local camCF = Camera.CFrame local goalCF = CFrame.new(camCF.Position, target.worldPos) if CFG.aimbotSmoothing <= 0 then Camera.CFrame = goalCF; return end local alpha = dt / (CFG.aimbotSmoothing + dt) Camera.CFrame = camCF:Lerp(goalCF, alpha) end -- ══════════════════════════════════════════════════════════════ -- RENDER LOOP -- ══════════════════════════════════════════════════════════════ RunService.RenderStepped:Connect(function(dt) lastDt = dt UpdateESP() if not CFG.aimbotEnabled then fovCircle.Visible=false; aimDot.Visible=false; return end local vp = Camera.ViewportSize local center = Vector2.new(vp.X/2, vp.Y/2) fovCircle.Position = center; fovCircle.Radius = CFG.aimbotFOV; fovCircle.Visible = true if not AimKeyHeld() then aimDot.Visible=false; return end local target = GetBestTarget() if not target then aimDot.Visible=false; return end aimDot.Position = target.screenPos; aimDot.Visible = true SmoothAim(target, dt) end) -- ══════════════════════════════════════════════════════════════ -- GUI -- ══════════════════════════════════════════════════════════════ pcall(function() local old = LocalPlayer.PlayerGui:FindFirstChild("SolarGUI") if old then old:Destroy() end end) local ScreenGui = Instance.new("ScreenGui") ScreenGui.Name = "SolarGUI" ScreenGui.ResetOnSpawn = false ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global ScreenGui.IgnoreGuiInset = true ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui") -- ── Palette ─────────────────────────────────────────────────── local C = { bg = Color3.fromRGB(9, 7, 18), panel = Color3.fromRGB(13, 10, 26), card = Color3.fromRGB(20, 15, 38), cardHov = Color3.fromRGB(28, 21, 52), hdr = Color3.fromRGB(14, 10, 30), accent = Color3.fromRGB(105, 30, 215), accentLt = Color3.fromRGB(155, 80, 255), accentDm = Color3.fromRGB(52, 14, 110), div = Color3.fromRGB(32, 20, 58), txtPri = Color3.fromRGB(230, 218, 255), txtSec = Color3.fromRGB(128, 100, 180), txtDim = Color3.fromRGB(60, 44, 100), green = Color3.fromRGB(50, 220, 110), red = Color3.fromRGB(255, 60, 60), slBg = Color3.fromRGB(16, 11, 32), slFill = Color3.fromRGB(100, 28, 210), slKnob = Color3.fromRGB(185, 115, 255), } local PW=360; local PH=530; local HDR=44 local Panel = Instance.new("Frame", ScreenGui) Panel.Size=UDim2.new(0,PW,0,PH); Panel.Position=UDim2.new(0.04,0,0.06,0) Panel.BackgroundColor3=C.bg; Panel.BorderSizePixel=0; Panel.ClipsDescendants=false Instance.new("UICorner",Panel).CornerRadius=UDim.new(0,12) -- Outer glow ring local Glow=Instance.new("Frame",Panel) Glow.Size=UDim2.new(1,14,1,14); Glow.Position=UDim2.new(0,-7,0,-7) Glow.BackgroundColor3=C.accent; Glow.BackgroundTransparency=0.76 Glow.ZIndex=0; Glow.BorderSizePixel=0 Instance.new("UICorner",Glow).CornerRadius=UDim.new(0,18) -- Header local Header=Instance.new("Frame",Panel) Header.Size=UDim2.new(1,0,0,HDR); Header.BackgroundColor3=C.hdr Header.BorderSizePixel=0; Header.ZIndex=3 Instance.new("UICorner",Header).CornerRadius=UDim.new(0,12) local HPatch=Instance.new("Frame",Header) -- square off bottom corners HPatch.Size=UDim2.new(1,0,0,12); HPatch.Position=UDim2.new(0,0,1,-12) HPatch.BackgroundColor3=C.hdr; HPatch.BorderSizePixel=0 -- Accent strip local Strip=Instance.new("Frame",Header) Strip.Size=UDim2.new(0,3,1,-14); Strip.Position=UDim2.new(0,0,0,7) Strip.BackgroundColor3=C.accentLt; Strip.BorderSizePixel=0 Instance.new("UICorner",Strip).CornerRadius=UDim.new(0,2) local TitleLbl=Instance.new("TextLabel",Header) TitleLbl.Size=UDim2.new(1,-70,1,0); TitleLbl.Position=UDim2.new(0,11,0,0) TitleLbl.BackgroundTransparency=1; TitleLbl.Font=Enum.Font.GothamBold; TitleLbl.TextSize=15 TitleLbl.TextColor3=C.txtPri; TitleLbl.Text="✦ solar" TitleLbl.TextXAlignment=Enum.TextXAlignment.Left -- Minimize button local MinBtn=Instance.new("TextButton",Header) MinBtn.Size=UDim2.new(0,26,0,22); MinBtn.Position=UDim2.new(1,-32,0.5,-11) MinBtn.BackgroundColor3=C.accentDm; MinBtn.BorderSizePixel=0 MinBtn.Font=Enum.Font.GothamBold; MinBtn.TextSize=11 MinBtn.TextColor3=C.accentLt; MinBtn.Text="—"; MinBtn.ZIndex=4 Instance.new("UICorner",MinBtn).CornerRadius=UDim.new(0,6) -- Body local Body=Instance.new("Frame",Panel) Body.Size=UDim2.new(1,0,0,PH-HDR); Body.Position=UDim2.new(0,0,0,HDR) Body.BackgroundTransparency=1; Body.ClipsDescendants=true -- Tab bar local TabBar=Instance.new("Frame",Body) TabBar.Size=UDim2.new(1,-16,0,30); TabBar.Position=UDim2.new(0,8,0,7) TabBar.BackgroundTransparency=1 -- Content pane local Content=Instance.new("Frame",Body) Content.Size=UDim2.new(1,-16,1,-48); Content.Position=UDim2.new(0,8,0,44) Content.BackgroundColor3=C.panel; Content.BorderSizePixel=0; Content.ClipsDescendants=true Instance.new("UICorner",Content).CornerRadius=UDim.new(0,10) -- ── Tab system ──────────────────────────────────────────────── local tabList={}; local CW=PW-28 local function SelectTab(name) for _,t in pairs(tabList) do local on=t.name==name TweenService:Create(t.btn,TweenInfo.new(0.12),{ BackgroundColor3=on and C.accent or C.card, TextColor3 =on and C.txtPri or C.txtDim, }):Play() t.sf.Visible=on end end local function AddTab(name) local btn=Instance.new("TextButton",TabBar) btn.BackgroundColor3=C.card; btn.BorderSizePixel=0 btn.Font=Enum.Font.GothamBold; btn.TextSize=11 btn.TextColor3=C.txtDim; btn.Text=name Instance.new("UICorner",btn).CornerRadius=UDim.new(0,8) local sf=Instance.new("ScrollingFrame",Content) sf.Size=UDim2.new(1,0,1,0); sf.BackgroundTransparency=1; sf.BorderSizePixel=0 sf.ScrollBarThickness=3; sf.ScrollBarImageColor3=C.accentDm sf.CanvasSize=UDim2.new(0,0,0,0); sf.Visible=false local lay=Instance.new("UIListLayout",sf) lay.Padding=UDim.new(0,5); lay.HorizontalAlignment=Enum.HorizontalAlignment.Center lay.Changed:Connect(function() sf.CanvasSize=UDim2.new(0,0,0,lay.AbsoluteContentSize.Y+10) end) local pad=Instance.new("UIPadding",sf) pad.PaddingTop=UDim.new(0,7); pad.PaddingLeft=UDim.new(0,4); pad.PaddingRight=UDim.new(0,4) table.insert(tabList,{name=name,btn=btn,sf=sf}) btn.MouseButton1Click:Connect(function() SelectTab(name) end) return sf end -- Key tab is first; ESP + Aimbot are locked until key is entered local keySF = AddTab("🔑 Key") local espSF = AddTab("👁 ESP") local aimSF = AddTab("🎯 Aimbot") -- Store which tabs require unlock local lockedTabs = { ["👁 ESP"]=true, ["🎯 Aimbot"]=true } -- Override SelectTab to block locked tabs local _rawSelect = SelectTab SelectTab = function(name) if lockedTabs[name] and not keyUnlocked then -- Flash the Key tab button to hint the user for _,t in pairs(tabList) do if t.name == "🔑 Key" then TweenService:Create(t.btn, TweenInfo.new(0.07), {BackgroundColor3=Color3.fromRGB(160,40,255)}):Play() task.delay(0.14, function() TweenService:Create(t.btn, TweenInfo.new(0.1), {BackgroundColor3=C.accent}):Play() end) end end return -- block navigation end _rawSelect(name) end do -- layout tabs local n=#tabList; local gap=4 local bw=math.floor((PW-16-gap*(n-1))/n) for i,t in ipairs(tabList) do t.btn.Size=UDim2.new(0,bw,1,0); t.btn.Position=UDim2.new(0,(i-1)*(bw+gap),0,0) end end -- Dim locked tab buttons so they look inactive local function Ref