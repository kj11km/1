local function GetBestTarget()
    local vp     = Camera.ViewportSize
    local center = Vector2.new(vp.X/2, vp.Y/2)
    local myChar = GetChar()
    local myRoot = GetRoot()
    local best, bestDist = nil, CFG.aimbotFOV

    for _, pl in pairs(Players:GetPlayers()) do
        if pl == LocalPlayer then continue end
        if CFG.aimbotTeamCheck and IsTeammate(pl) then continue end
        local tChar = pl.Character; if not tChar then continue end
        local hum   = tChar:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local bone = tChar:FindFirstChild(CFG.aimbotBone)
                  or tChar:FindFirstChild("Head")
                  or tChar:FindFirstChild("UpperTorso")
                  or tChar:FindFirstChild("HumanoidRootPart")
        if not bone then continue end
        
        -- ── FIXED visibility check ────────────────────────────
        -- Only run if enabled AND we have a valid root
        if CFG.aimbotVisible and myRoot then
            local origin = myRoot.Position
            local dir    = bone.Position - origin
            local dist   = dir.Magnitude
            if dist > 1 then
                -- Offset origin slightly forward, stop 1 stud before bone
                -- so we don't clip our own character or the target's hitbox
                local ray = Ray.new(
                    origin + dir.Unit * 3,
                    dir.Unit * math.max(dist - 4, 0.1)
                )
                local hit = Workspace:FindPartOnRayWithIgnoreList(
                    ray, { myChar, tChar, espFolder }
                )
                -- hit=nil means clear line of sight → proceed
                -- hit=something means blocked → skip this target
                if hit then continue end
            end
        end

        -- Project to screen space
        local raw = Camera:WorldToViewportPoint(bone.Position)
        if raw.Z <= 0 then continue end  -- behind camera

        local sp = Vector2.new(raw.X, raw.Y)
        local d  = (sp - center).Magnitude
        if d < bestDist then
            bestDist = d
            best = { worldPos=bone.Position, screenPos=sp }
        end
    end
    return best
end
-- ── FIXED smooth aim  ──────────────────────────────────────────
-- Frame-rate independent using delta time.
-- alpha = dt / (smoothing_seconds + dt)
-- At dt=1/60 and smoothing=0.12 → alpha ≈ 0.33 per frame → ~3 frames to lock
-- At smoothing=0    → alpha=1 → instant snap every frame
local lastDt = 1/60

local function SmoothAim(target, dt)
    local camCF  = Camera.CFrame
    local goalCF = CFrame.new(camCF.Position, target.worldPos)
    if CFG.aimbotSmoothing <= 0 then
        Camera.CFrame = goalCF; return
    end
    local alpha = dt / (CFG.aimbotSmoothing + dt)
    Camera.CFrame = camCF:Lerp(goalCF, alpha)
end

-- ══════════════════════════════════════════════════════════════
-- RENDER LOOP
-- ══════════════════════════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    lastDt = dt
    UpdateESP()

    if not CFG.aimbotEnabled then
        fovCircle.Visible=false; aimDot.Visible=false; return
    end

    local vp     = Camera.ViewportSize
    local center = Vector2.new(vp.X/2, vp.Y/2)
    fovCircle.Position = center; fovCircle.Radius = CFG.aimbotFOV; fovCircle.Visible = true

    if not AimKeyHeld() then aimDot.Visible=false; return end

    local target = GetBestTarget()
    if not target then aimDot.Visible=false; return end

    aimDot.Position = target.screenPos; aimDot.Visible = true
    SmoothAim(target, dt)
end)

